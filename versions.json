{
  "_meta": {
    "schema_version": "2.0",
    "last_updated": "2026-06-24",
    "updated_by": "Podium 1 Racing",
    "notes": "Approved versions for all Podium 1 sim rigs. Update this file to push new approved versions fleet-wide."
  },
  "components": {
    "nvidia_driver": {
      "label": "NVIDIA GPU Driver",
      "approved_version": "610.62",
      "minimum_version": "610.62",
      "update_url": "https://www.nvidia.com/en-us/drivers/",
      "notes": "Approved after vetting for iRacing + ACC stability.",
      "check_method": "nvidia_smi"
    },
    "windows_update": {
      "label": "Windows Update",
      "policy": "auto",
      "notes": "All pending Windows updates should be applied.",
      "check_method": "wua_api"
    },
    "asetek_racehub": {
      "label": "Asetek RaceHub",
      "approved_version": "4.4.7",
      "minimum_version": "4.4.7",
      "exe_name": "RaceHub™.exe",
      "install_path_hint": "C:\\Program Files\\Asetek SimSports\\RaceHub™\\Application Folder\\Build",
      "update_url": "https://www.asetek.com/simsports/racehub/",
      "notes": "Version detected from firmware filename \"4.4.7 - Firmware Versions\" in Firmware Update Tools/Firmware Files folder."
    },
    "moza_pithouse": {
      "label": "MOZA Pit House",
      "approved_version": "1.3.9.36",
      "minimum_version": "1.3.9.36",
      "exe_name": "MOZA Pit House.exe",
      "registry_key": "HKCU\\SOFTWARE\\MOZA\\PitHouse",
      "registry_value": "path",
      "install_path_hint": "C:\\Program Files (x86)\\MOZA Pit House\\bin",
      "update_url": "C:\\Program Files (x86)\\MOZA Pit House\\bin\\MOZA Pit House.exe",
      "notes": "Registry stores exe path under HKCU. Version read directly from exe. Also covers MOZA pedals."
    },
    "simucube_tuner": {
      "label": "Simucube Tuner",
      "approved_version": "3.1.3",
      "minimum_version": "3.1.3",
      "exe_name": "sc-tuner.exe",
      "install_path_hint": "C:\\Program Files\\SimucubeTuner",
      "update_url": "https://simucube.com/en-us/simucube-tuner-3-0-software/",
      "notes": "Version read from version file in install directory. Covers Simucube wheelbase and Active Pedals."
    },
    "fanatec_app": {
      "label": "Fanatec App",
      "approved_version": "1.5.1+2",
      "minimum_version": "1.5.1+2",
      "exe_name": "Fanatec.exe",
      "install_path_hint": "C:\\Program Files\\Fanatec\\FanatecUI\\UI",
      "update_url": "https://www.fanatec.com/us/en/s/download-apps-driver",
      "notes": "Version read from exe. Required for all Fanatec hardware."
    },
    "heusinkveld_app": {
      "label": "Heusinkveld SmartControl",
      "approved_version": "1.0.0",
      "minimum_version": "1.0.0",
      "exe_name": "SmartControl.exe",
      "registry_key": "HKLM\\SOFTWARE\\Heusinkveld\\HeusinkveldApp",
      "registry_value": "Version",
      "install_path_hint": "C:\\Program Files\\Heusinkveld\\SmartControl",
      "update_url": "https://heusinkveld.com/smartcontrol/",
      "notes": ""
    },
    "simhub": {
      "label": "SimHub",
      "approved_version": "9.4.2",
      "minimum_version": "9.0.0",
      "exe_name": "SimHubWPF.exe",
      "registry_key": "HKLM\\SOFTWARE\\SimHub",
      "registry_value": "Version",
      "install_path_hint": "C:\\Program Files (x86)\\SimHub",
      "update_url": "https://www.simhubdash.com/",
      "notes": ""
    },
    "streamdeck": {
      "label": "Stream Deck",
      "optional": true,
      "approved_version": "6.8.0",
      "minimum_version": "6.5.0",
      "exe_name": "StreamDeck.exe",
      "registry_key": "HKLM\\SOFTWARE\\Elgato Systems GmbH\\StreamDeck",
      "registry_value": "Version",
      "install_path_hint": "C:\\Program Files\\Elgato\\StreamDeck",
      "update_url": "https://www.elgato.com/downloads",
      "notes": "Optional add-on. Only checked on rigs where installed."
    },
    "sensit_haptics": {
      "label": "Sensit Seat Haptics",
      "optional": true,
      "approved_version": "0.10.3",
      "minimum_version": "0.10.3",
      "exe_name": "simracing.exe",
      "install_path_hint": "C:\\Program Files\\SensitHaptics SimRacing Cockpit",
      "update_url": "https://sensithaptics.com/pages/downloads",
      "notes": "Optional add-on. Only checked on rigs where installed."
    }
  },
