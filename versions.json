  },

  "components": {

    "nvidia_driver": {
      "label": "NVIDIA GPU Driver",
      "approved_version": "610.62",
      "minimum_version": "610.62",
      "update_url": "https://www.nvidia.com/en-us/drivers/",
      "notes": "Approved after vetting for iRacing + ACC stability. Do not update to 576.x until further notice.",
      "check_method": "nvidia_smi"
    },

    "windows_update": {
      "label": "Windows Update",
      "policy": "auto",
      "notes": "All pending Windows updates should be applied. Red if more than 7 days overdue.",
      "check_method": "wua_api"
    },

    "asetek_racehub": {
      "label": "Asetek RaceHub",
      "approved_version": "1.6.2",
      "minimum_version": "1.5.0",
      "exe_name": "RaceHub.exe",
      "registry_key": "HKLM\\SOFTWARE\\Asetek\\RaceHub",
      "registry_value": "Version",
      "install_path_hint": "C:\\Program Files\\Asetek\\RaceHub",
      "update_url": "https://www.asetek.com/sim-sports/software/",
      "notes": ""
    },

    "moza_pithouse": {
      "label": "MOZA Pit House",
      "approved_version": "1.3.9.36",
      "minimum_version": "1.3.9.36",
      "exe_name": "MOZA Pit House.exe",
      "registry_key": "HKCU\\SOFTWARE\\MOZA\\PitHouse",
      "registry_value": "path",
      "install_path_hint": "C:\\Program Files (x86)\\MOZA Pit House\\bin",
      "update_url": "C:\Program Files (x86)\MOZA Pit House",
      "notes": "Registry stores exe path under HKCU. Version read directly from exe."
